# Application
APP_NAME=Universal Web Scraper
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Worker
WORKER_CONCURRENCY=10
WORKER_BROWSER_INSTANCES=5
WORKER_TIMEOUT=30

# Playwright
PLAYWRIGHT_BROWSER_TYPE=chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# Stealth
STEALTH_USER_AGENT_ROTATION=true
STEALTH_PROXY_ROTATION=false

# Extraction
EXTRACTION_PROVIDER=openai
EXTRACTION_MODEL=gpt-4o-mini
EXTRACTION_TEMPERATURE=0.0
EXTRACTION_MAX_TOKENS=4000

# API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Proxies (comma-separated)
PROXIES=
